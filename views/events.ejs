<%- include('partials/head') %>
<div class="app-layout">
  <% if (user.role === 'owner') { %>
    <%- include('partials/sidebar-owner') %>
  <% } else { %>
    <%- include('partials/sidebar-employee') %>
  <% } %>

  <main class="main-content">
    <div class="page-header">
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
        <div>
          <h1 class="page-title">📅 Scheduled Events</h1>
          <p class="page-desc">All upcoming and past events. New events appear instantly.</p>
        </div>
        <% if (user.role === 'owner') { %>
          <a href="/events/create" class="btn btn-primary">➕ Schedule Event</a>
        <% } %>
      </div>
    </div>

    <div id="eventsContainer">
      <% if (events.length === 0) { %>
        <div class="empty-state card" id="noEvents">
          <div class="empty-icon">📅</div>
          <p>No events scheduled yet.</p>
        </div>
      <% } else { %>
        <div class="events-grid" id="eventsGrid">
          <% events.forEach(function(ev) { %>
            <div class="event-card card" id="event-<%= ev.id %>">
              <div class="event-card-header">
                <span class="badge badge-event-type badge-event-<%= ev.type.toLowerCase() %>"><%= ev.type %></span>
                <% if (user.role === 'owner') { %>
                  <form method="POST" action="/events/<%= ev.id %>/delete" class="delete-event-form">
                    <button type="submit" class="btn-delete-event" title="Delete event">✕</button>
                  </form>
                <% } %>
              </div>
              <h3 class="event-title"><%- ev.title %></h3>
              <% if (ev.description) { %><p class="event-desc"><%- ev.description %></p><% } %>
              <div class="event-times">
                <span class="event-time-label">Starts:</span>
                <span class="event-time"><%= new Date(ev.startsAt).toLocaleString('en-US',{weekday:'short',month:'short',day:'numeric',year:'numeric',hour:'2-digit',minute:'2-digit'}) %></span>
                <% if (ev.endsAt) { %>
                  <span class="event-time-label" style="margin-top:0.2rem;">Ends:</span>
                  <span class="event-time"><%= new Date(ev.endsAt).toLocaleString('en-US',{weekday:'short',month:'short',day:'numeric',year:'numeric',hour:'2-digit',minute:'2-digit'}) %></span>
                <% } %>
              </div>
              <div class="event-footer">
                <span class="meta-text">by <strong><%= ev.createdBy %></strong></span>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- Live event toast -->
    <div id="eventToast" class="event-toast" style="display:none"></div>
  </main>
</div>

<script>
  const IS_OWNER = '<%= user.role %>' === 'owner';
  const socket   = window._portalSocket;

  function escapeHtml(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function formatDt(iso) {
    return new Date(iso).toLocaleString('en-US',{weekday:'short',month:'short',day:'numeric',year:'numeric',hour:'2-digit',minute:'2-digit'});
  }

  function showToast(msg) {
    const t = document.getElementById('eventToast');
    t.textContent = msg;
    t.style.display = 'block';
    t.classList.add('toast-show');
    setTimeout(() => { t.classList.remove('toast-show'); setTimeout(() => t.style.display='none', 400); }, 4000);
  }

  function buildEventCard(ev) {
    const typeClass = ev.type.toLowerCase();
    const deleteBtn = IS_OWNER
      ? `<form method="POST" action="/events/${ev.id}/delete" class="delete-event-form"><button type="submit" class="btn-delete-event" title="Delete event">✕</button></form>`
      : '';
    const endsRow = ev.endsAt
      ? `<span class="event-time-label" style="margin-top:0.2rem;">Ends:</span><span class="event-time">${formatDt(ev.endsAt)}</span>`
      : '';
    const desc = ev.description
      ? `<p class="event-desc">${escapeHtml(ev.description)}</p>`
      : '';
    return `
      <div class="event-card card event-new-flash" id="event-${ev.id}">
        <div class="event-card-header">
          <span class="badge badge-event-type badge-event-${typeClass}">${escapeHtml(ev.type)}</span>
          ${deleteBtn}
        </div>
        <h3 class="event-title">${escapeHtml(ev.title)}</h3>
        ${desc}
        <div class="event-times">
          <span class="event-time-label">Starts:</span>
          <span class="event-time">${formatDt(ev.startsAt)}</span>
          ${endsRow}
        </div>
        <div class="event-footer">
          <span class="meta-text">by <strong>${escapeHtml(ev.createdBy)}</strong></span>
        </div>
      </div>`;
  }

  // New event broadcast
  socket.on('event:new', (ev) => {
    const noEvents = document.getElementById('noEvents');
    if (noEvents) {
      noEvents.remove();
      const container = document.getElementById('eventsContainer');
      container.innerHTML = '<div class="events-grid" id="eventsGrid"></div>';
    }
    const grid = document.getElementById('eventsGrid');
    if (grid) grid.insertAdjacentHTML('afterbegin', buildEventCard(ev));
    showToast(`📅 New event: "${ev.title}"`);
  });

  // Event deleted broadcast
  socket.on('event:deleted', ({ id }) => {
    const card = document.getElementById('event-' + id);
    if (card) {
      card.style.transition = 'opacity 0.3s ease';
      card.style.opacity = '0';
      setTimeout(() => card.remove(), 300);
    }
  });

  // Notification badge is handled globally in head.ejs
</script>
</body></html>
