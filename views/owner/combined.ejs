<%- include('../partials/head') %>

<div class="app-layout">
  <%- include('../partials/sidebar-owner') %>

  <main class="main-content">
    <div class="page-header">
      <h1 class="page-title">🔀 Combined Timeline</h1>
      <p class="page-desc">All <%= items.length %> submission<%= items.length !== 1 ? 's' : '' %>, newest first.</p>
    </div>

    <% if (items.length === 0) { %>
      <div class="empty-state card">
        <div class="empty-icon">🔀</div>
        <p>No submissions yet.</p>
      </div>
    <% } else { %>
      <div class="timeline">
        <% items.forEach(function(item) { %>
          <div class="timeline-item card">
            <div class="timeline-header">
              <span class="badge badge-type-<%= item._type.split(' ')[0].toLowerCase() %>"><%= item._type %></span>
              <span class="meta-text">by <strong><%= item.submitter %></strong></span>
              <span class="meta-text timeline-date"><%= new Date(item.createdAt).toLocaleString('en-US', {month:'short', day:'numeric', year:'numeric', hour:'2-digit', minute:'2-digit'}) %></span>
            </div>
            <h3 class="timeline-title"><%- item.name || item.title %></h3>
            <p class="item-text"><%- item.description %></p>
          </div>
        <% }) %>
      </div>
    <% } %>
  </main>
</div>

</body>
</html>
