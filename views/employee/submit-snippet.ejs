<%- include('../partials/head') %>

<div class="app-layout">
  <%- include('../partials/sidebar-employee') %>

  <main class="main-content">
    <div class="page-header">
      <h1 class="page-title">&lt;/&gt; Submit UI Code Snippet</h1>
      <p class="page-desc">Share a useful HTML/CSS/JS snippet with the team.</p>
    </div>

    <% if (flash) { %>
      <div class="alert alert-success"><%= flash %></div>
    <% } %>
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div class="card">
      <form action="/employee/submit-snippet" method="POST" class="form" autocomplete="off">

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="title">Snippet Title <span class="required">*</span></label>
            <input type="text" id="title" name="title" class="form-input" placeholder="e.g. Animated nav hover effect" required maxlength="150" />
          </div>
          <div class="form-group">
            <label class="form-label" for="language">Language</label>
            <select id="language" name="language" class="form-select">
              <option value="HTML/CSS/JS" selected>HTML/CSS/JS</option>
              <option value="HTML">HTML</option>
              <option value="CSS">CSS</option>
              <option value="JavaScript">JavaScript</option>
              <option value="Other">Other</option>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="description">Description <span class="required">*</span></label>
          <textarea id="description" name="description" class="form-textarea" placeholder="What does this snippet do? When should it be used?" required maxlength="500" rows="3"></textarea>
        </div>

        <div class="form-group">
          <label class="form-label" for="code">Code <span class="required">*</span></label>
          <textarea id="code" name="code" class="form-textarea code-input" placeholder="Paste your code here..." required maxlength="50000" rows="16" spellcheck="false"></textarea>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Submit Snippet</button>
        </div>

      </form>
    </div>
  </main>
</div>

</body>
</html>
